<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>خط الإنتاج | مصنع صلاح الدين</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;600;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --primary: #4338ca;
            --secondary: #6366f1;
            --bg: #f8fafc;
            --text: #1e293b;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--bg);
            color: var(--text);
            margin: 0;
            padding: 20px;
        }

        .container { max-width: 950px; margin: 0 auto; }

        .header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
        }

        /* كارت تسجيل العجنة */
        .production-card {
            background: white;
            padding: 25px;
            border-radius: 20px;
            box-shadow: 0 10px 15px -3px rgba(0,0,0,0.1);
            border-right: 8px solid var(--primary);
            margin-bottom: 30px;
        }

        .form-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
            gap: 20px;
            margin-top: 15px;
        }

        .form-group { display: flex; flex-direction: column; gap: 8px; }

        input, select {
            padding: 12px;
            border: 1px solid #e2e8f0;
            border-radius: 10px;
            font-family: 'Cairo';
        }

        .btn-start {
            background: var(--primary);
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 12px;
            cursor: pointer;
            font-weight: 800;
            width: 100%;
            margin-top: 20px;
            transition: 0.3s;
        }

        .btn-start:hover { background: var(--secondary); }

        /* جدول المخرجات */
        .output-table {
            width: 100%;
            background: white;
            border-radius: 20px;
            overflow: hidden;
            border-collapse: collapse;
            box-shadow: 0 4px 6px -1px rgba(0,0,0,0.1);
        }

        .output-table th { background: var(--primary); color: white; padding: 18px; text-align: right; }
        .output-table td { padding: 15px; border-bottom: 1px solid #f1f5f9; }

        .status-ready { background: #dcfce7; color: #166534; padding: 4px 10px; border-radius: 15px; font-size: 13px; }
    </style>
</head>
<body>

<div class="container">
    <div class="header">
        <a href="index.html" style="text-decoration:none; color: var(--primary); font-weight:700;">⬅️ رجوع</a>
        <h2>مراقب خط الإنتاج (العجن والتصنيع) 🥣</h2>
    </div>

    <div class="production-card">
        <h3>تسجيل دورة إنتاج جديدة</h3>
        <div class="form-grid">
            <div class="form-group">
                <label>الصنف المُراد إنتاجه</label>
                <select id="productName">
                    <option value="بسبوسة">بسبوسة</option>
                    <option value="كعك">كعك</option>
                    <option value="بيتيفور">بيتيفور</option>
                    <option value="مشكل">مشكل فخم</option>
                </select>
            </div>
            <div class="form-group">
                <label>كمية الدقيق المستخدمة (كجم)</label>
                <input type="number" id="flourUsed" placeholder="0">
            </div>
            <div class="form-group">
                <label>الكمية المنتجة (بالقطعة/الكرتونة)</label>
                <input type="number" id="outputQty" placeholder="0">
            </div>
            <div class="form-group">
                <label>رئيس العجانين</label>
                <input type="text" id="chief" placeholder="اسم المسؤول">
            </div>
        </div>
        <button class="btn-start" onclick="logProduction()">اعتماد الإنتاج في المخزن النهائي ✅</button>
    </div>

    <table class="output-table" id="productionLog">
        <thead>
            <tr>
                <th>الوقت</th>
                <th>الصنف</th>
                <th>المواد المستهلكة</th>
                <th>الإنتاج النهائي</th>
                <th>المسؤول</th>
                <th>الحالة</th>
            </tr>
        </thead>
        <tbody>
            </tbody>
    </table>
</div>

<script>
    function logProduction() {
        const product = document.getElementById('productName').value;
        const flour = document.getElementById('flourUsed').value;
        const qty = document.getElementById('outputQty').value;
        const chief = document.getElementById('chief').value;
        const time = new Date().toLocaleTimeString('ar-EG', {hour: '2-digit', minute:'2-digit'});

        if(flour && qty && chief) {
            const table = document.getElementById('productionLog').getElementsByTagName('tbody')[0];
            const row = table.insertRow(0);

            row.innerHTML = `
                <td>${time}</td>
                <td><strong>${product}</strong></td>
                <td>${flour} كجم دقيق</td>
                <td>${qty} وحدة جاهزة</td>
                <td>${chief}</td>
                <td><span class="status-ready">جاهز للتغليف</span></td>
            `;

            // تنظيف
            document.getElementById('flourUsed').value = "";
            document.getElementById('outputQty').value = "";
        } else {
            alert("يرجى إكمال تفاصيل العجنة");
        }
    }
</script>

</body>
</html>
